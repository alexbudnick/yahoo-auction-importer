# Required
AIRTABLE_TOKEN=pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appxxxxxxxxxxxxxx
AIRTABLE_TABLE_NAME=Table 1

# Optional
AIRTABLE_VIEW_NAME=Grid view
DRY_RUN=true
MAX_RECORDS=100
REQUEST_DELAY_MS=900

# Field names in your Airtable base
FIELD_URL=Auction Link
FIELD_TITLE=Title (Auction Link)
FIELD_CURRENT_BID=Current Bid JPY
FIELD_BUYOUT=Buyout Price JPY
FIELD_BID_COUNT=Bid Count
FIELD_END_TIME=End Time
FIELD_STATUS=Auction Status
FIELD_FINAL=Final Price JPY
FIELD_LAST_CHECKED=Last Checked
FIELD_ERROR=Error Notes
FIELD_MY_MAX=My Max Bid JPY
FIELD_BID_RESULT=Bid Result

# Optional behavior
# Leave false for now because public Yahoo pages cannot truly confirm your account won.
INFER_BID_RESULT=false
